[user]
      email = filip.harald@gmail.com
	    name = filip
[blame]
      date = short
[pull]
      rebase = false
[push]
      autoSetupRemote = true
[merge]
      conflictstyle = diff3
[filter "lfs"]
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true
	clean = git-lfs clean -- %f
